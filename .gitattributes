# Normalize line endings: LF in repo, auto-convert on checkout
* text=auto eol=lf

# Windows-specific scripts stay CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary
*.woff binary
*.woff2 binary
*.pdf binary
