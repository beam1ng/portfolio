# Copy to .env and fill. .env is gitignored — never commit real secrets.
#
# IMPORTANT: avoid '$' and '#' in any value here. docker compose treats '$' as
# variable interpolation, so a password like "ab$cd" reaches the container as
# just "ab" (and the DB fails to start / the admin login breaks). Use letters,
# digits, and safe symbols such as ! - _ . instead.

# ---- MS SQL Server (local docker) ----
MSSQL_SA_PASSWORD=Your_strong_Passw0rd!
MSSQL_DB=PortfolioDb
MSSQL_PORT=1433

# ---- Backend API ----
# Connection string built from the MSSQL_* vars in docker-compose; override here if needed.
ASPNETCORE_ENVIRONMENT=Development
API_HTTP_PORT=8080

# JWT (admin auth) — generate a long random value for production
JWT__ISSUER=portfolio-api
JWT__AUDIENCE=portfolio-web
JWT__SIGNINGKEY=change-me-to-a-long-random-secret-at-least-32-chars

# Seeded admin user (development only)
ADMIN__EMAIL=admin@example.com
ADMIN__PASSWORD=Admin_Passw0rd!

# ---- Frontend ----
WEB_PORT=5173
# Relative — nginx (prod) and the Vite dev proxy both forward /api to the API.
VITE_API_BASE_URL=/api/v1
